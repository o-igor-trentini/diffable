# =============================================================================
# Diffable Backend — Environment Variables
# Copy to .env and fill in required values.
# =============================================================================

# -- Required (app will not start without these) ------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5433/diffable?sslmode=disable
BITBUCKET_EMAIL=user@example.com
BITBUCKET_API_TOKEN=your-token
OPENAI_API_KEY=sk-...

# -- Optional (defaults shown) -----------------------------------------------

# Server
# PORT=8080
# FRONTEND_URL=http://localhost:3000
# LOG_LEVEL=info
# SHUTDOWN_TIMEOUT=30s

# Bitbucket
# BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0
# BITBUCKET_TIMEOUT=30s

# OpenAI
# OPENAI_DEFAULT_MODEL=gpt-4o-mini
# OPENAI_COMPLEX_MODEL=gpt-4o
# OPENAI_MAX_TOKENS=1024
# OPENAI_TEMPERATURE=0.3
# OPENAI_TOKEN_THRESHOLD=4000

# Cache
# CACHE_TTL=24h

# Database Pool
# DB_MAX_CONNS=25
# DB_MIN_CONNS=5

# Rate Limit
# RATE_LIMIT_RPM=60
