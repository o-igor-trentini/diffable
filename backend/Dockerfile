FROM golang:1.22-alpine AS build

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /server ./cmd/server

FROM gcr.io/distroless/static-debian12

COPY --from=build /server /server
COPY --from=build /app/migrations /migrations

EXPOSE 8080

ENTRYPOINT ["/server"]
